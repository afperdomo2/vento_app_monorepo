{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} [$__interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Logs (Last 5 minutes)",
      "type": "stat",
      "datasource": "Loki",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\".+\"} |~ \"(?i)error|exception|fatal\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Logs by Level",
      "type": "piechart",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({service=~\".+\"} [$__range]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Logs by Service",
      "type": "piechart",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 8 },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} [$__range]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "Recent ERROR Logs",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "{service=~\".+\"} |~ \"(?i)error|exception|fatal\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 6,
      "title": "All Logs (Log Explorer)",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"$log_filter\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["logs", "loki", "observability"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(service)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "label": "Service"
      },
      {
        "name": "log_filter",
        "type": "textbox",
        "label": "Log Filter (regex)",
        "description": "Filter logs by keyword (regex supported)",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Vento - Log Explorer",
  "uid": "vento-logs",
  "version": 1
}
