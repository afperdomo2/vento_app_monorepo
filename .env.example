# =============================================================================
# Vento App - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno.
#
# Uso:
#   - Local: No es necesario (usa valores hardcodeados en application-local.yml)
#   - Dev: Copia a .env y ajusta para desarrollo en Docker
#   - Prod: Usa valores seguros para producción
#
# Docker Compose:
#   - docker-compose.dev.yml usa estas variables
#   - docker-compose.prod.yml usa estas variables (requeridas)
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL - Event Service
# -----------------------------------------------------------------------------
POSTGRES_EVENTS_DB=events_db
POSTGRES_EVENTS_USER=postgres
POSTGRES_EVENTS_PASSWORD=postgres

# -----------------------------------------------------------------------------
# PostgreSQL - Order Service
# -----------------------------------------------------------------------------
POSTGRES_ORDERS_DB=orders_db
POSTGRES_ORDERS_USER=postgres
POSTGRES_ORDERS_PASSWORD=postgres

# -----------------------------------------------------------------------------
# PostgreSQL - Payment Service
# -----------------------------------------------------------------------------
POSTGRES_PAYMENTS_DB=payments_db
POSTGRES_PAYMENTS_USER=postgres
POSTGRES_PAYMENTS_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Keycloak - Autenticación
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# CORS - API Gateway
# -----------------------------------------------------------------------------
# Orígenes permitidos (separados por coma, sin espacios)
# Desarrollo: http://localhost:4200,http://localhost:3000
# Producción: https://tuapp.com,https://www.tuapp.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Métodos HTTP permitidos
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Headers permitidos
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Requested-With,Origin

# Headers expuestos al frontend (para que pueda leerlos)
CORS_EXPOSED_HEADERS=X-User-Id,X-User-Roles

# Permitir credenciales (true/false)
CORS_ALLOW_CREDENTIALS=true

# Max age para preflight caching (en segundos)
CORS_MAX_AGE=3600

# -----------------------------------------------------------------------------
# Frontend - API Configuration
# -----------------------------------------------------------------------------
# API Gateway URL (usada por el frontend Angular en Dockerfile.prod)
API_URL=http://localhost:8080

# Keycloak URL (usada por el frontend Angular en Dockerfile.prod)
KEYCLOAK_URL=http://localhost:8180

# Keycloak realm name
KEYCLOAK_REALM=vento-realm

# Keycloak client ID (public client for frontend)
KEYCLOAK_CLIENT_ID=vento-frontend

# -----------------------------------------------------------------------------
# Grafana - Dashboards & Monitoring
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Opciones Avanzadas (Opcional)
# -----------------------------------------------------------------------------
# Elasticsearch URI (usada por event-service)
# ELASTICSEARCH_URIS=http://localhost:9200

# Keycloak JWK Set URI (usada por api-gateway para validar JWT)
# KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/vento-realm/protocol/openid-connect/certs

# Server Ports (cuando se ejecutan con Gradle fuera de Docker)
# SERVER_PORT_EVENT=8082
# SERVER_PORT_ORDER=8083
# SERVER_PORT_PAYMENT=8084
# SERVER_PORT_GATEWAY=8080

# Database Ports (solo para conexiones directas desde el host)
# DATABASE_PORT_EVENTS=5432
# DATABASE_PORT_ORDERS=5433
# DATABASE_PORT_PAYMENTS=5434
