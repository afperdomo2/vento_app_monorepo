        },
        {
          "name": "Confirm Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Orden confirmada correctamente');",
                  "} else if (pm.response.code === 409) {",
                  "    console.error('❌ Conflict: La orden no está en estado PENDING (ya fue confirmada, cancelada o expirada)');",
                  "} else {",
                  "    console.error('❌ Error:', pm.response.code, pm.response.json());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
