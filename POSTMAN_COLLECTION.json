        {
          "name": "Decode Current Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('access_token');",
                  "if (token) {",
                  "    const parts = token.split('.');",
                  "    if (parts.length === 3) {",
                  "        const payload = JSON.parse(atob(parts[1]));",
                  "        console.log('📋 Payload del token:');",
                  "        console.log('  - sub:', payload.sub);",
                  "        console.log('  - username:', payload.preferred_username);",
                  "        console.log('  - roles:', payload.realm_access?.roles || []);",
                  "        console.log('  - exp:', new Date(payload.exp * 1000).toLocaleString());",
                  "    }",
                  "} else {",
                  "    console.error('❌ No hay token guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jwt.io",
              "protocol": "https",
              "host": [
                "jwt",
                "io"
              ]
            },
            "description": "Este request es solo informativo. Para decodificar el token, copia el valor de `access_token` y pégalo en https://jwt.io"
          },
          "response": []
        }
      ],
      "description": "Endpoints de autenticación con Keycloak"
