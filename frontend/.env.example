# =============================================================================
# Vento App - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
# Usage:
#   cp .env.example .env
#
# The .env file is gitignored and should contain local development values.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Base URL for the API Gateway
API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Keycloak Configuration
# -----------------------------------------------------------------------------
# Keycloak server URL
KEYCLOAK_URL=http://localhost:8180

# Keycloak realm name
KEYCLOAK_REALM=vento-realm

# Keycloak client ID (public client for frontend)
KEYCLOAK_CLIENT_ID=vento-frontend

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Application port (for development server)
# PORT=4200

# Enable/Enable debug mode
# DEBUG=false
